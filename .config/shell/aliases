#shorten common commands

alias sudo='sudo '
alias sdn='shutdown now'
alias ..='cd .. && pwd'

alias add='git add'
alias unadd='git reset HEAD'
alias commit='git commit -m'
alias push='git push origin main'
alias gd='git diff'
alias gs='git status -s'
alias oops='git reset HEAD^ --soft'

#colors and presets

alias cp='cp -i'
alias mv='mv -i'
alias l='ls -lAFhv --group-directories-first'
alias grep='grep'

#custom commands

alias wttr='curl wttr.in/Goteborg'
alias geo='curl -s https://ipinfo.io/'

alias rm='\mv --backup=t -t $@ ~/.cache/.trash/'
alias empty-trash='\rm -rf ~/.cache/.trash && mkdir ~/.cache/.trash'

alias wfl='nmcli dev wifi list'
alias wfc='nmcli dev wifi connect -a'

alias otp='pass otp code -c'
alias edu='pass gu -c && nmcli dev wifi connect eduroam -a'

alias vpn0='systemctl stop wg-quick@wg0.service'
alias vpn1='systemctl start wg-quick@wg0.service'

alias mute='wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle'

#functions

mkcd() {
  mkdir ${1}
  cd ${1}
}
bco() {
  for i in *.${1};
  do ffmpeg -i $i ${i%.${1}}.${2};
  done
}
met() {
  ecasound -q -i:null -o:alsa -pn:metronome,${1}
}
