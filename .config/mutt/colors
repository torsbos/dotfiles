# Custom settings

set header_cache = "~/.cache/mutt/headers"
set message_cachedir = "~/.cache/mutt/bodies"
set certificate_file = "~/.config/mutt/certificates"

mailboxes =INBOX =Drafts =All =Sent =Trash

macro index gd "<change-folder>$postponed<enter>" "go to drafts"
macro index gs "<change-folder>$record<enter>" "go to sent"
macro index gi "<change-folder>$spoolfile<Enter>" "go to inbox"
macro index gt "<change-folder>$trash<enter>" "go to trash"

set move = no
set sleep_time = 0
set mail_check = 10
set timeout = 5
set sort = reverse-date

alternative_order text/plain text/enriched text/html
#alternative_order multipart/mixed multipart/related text/plain
auto_view text/html
set mailcap_path = "~/.config/mutt/mailcap"

macro attach 'V' "<pipe-entry>iconv -c --to-code=UTF8 > ~/.cache/mutt/mail.html<enter><shell-escape>$BROWSER ~/.cache/mutt/mail.html<enter>"

## h to exit in every menu, l to go deeper, j and k for up and down, g and G for top and bottom
bind pager,browser			h			exit
bind attach,alias			h			exit
bind pager				l			view-attachments
bind pager 				k 			previous-line
bind pager 				j 			next-line
bind pager				g			top
bind pager				G			bottom
bind index				j			next-entry
bind index				k			previous-entry
bind attach,index 			g 			first-entry
bind attach,index 			G 			last-entry
bind index				l			display-message
bind attach				l			view-attach
bind browser,alias			l			select-entry
bind index				/			search
## default binding for limit is l
bind index				?			limit
## default binding for help is ?
bind index,pager,attach			<F1>			help
## default binding for header view (toggle-weed) is h
bind pager				H			display-toggle-weed
bind attach,index,pager 		\CD 			next-page
bind attach,index,pager 		\CU 			previous-page
# -*-muttrc-*-

# Palette for use with the Linux console.  Black background.

color hdrdefault black white
color quoted black white
color signature black white
color attachment white white
color prompt black white
color message black white
color error black white
color indicator white black
color status black white
color tree black white
color normal black white
color markers black white
color search black white
color tilde black white
color index black white ~F
color index black white "~N|~O"

