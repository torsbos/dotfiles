# Custom settings

set header_cache = "~/.cache/mutt/headers"
set message_cachedir = "~/.cache/mutt/bodies"
set certificate_file = "~/.config/mutt/certificates"

mailboxes =INBOX =Drafts =All =Sent =Trash

macro index gd "<change-folder>$postponed<enter>" "go to drafts"
macro index gs "<change-folder>$record<enter>" "go to sent"
macro index gi "<change-folder>$spoolfile<Enter>" "go to inbox"
macro index gt "<change-folder>$trash<enter>" "go to trash"

bind index G last-entry
bind index gg first-entry
bind index J half-down
bind index K half-up

set move = no
set sleep_time = 0
set mail_check = 10
set timeout = 5
set sort = reverse-date

alternative_order text/plain text/enriched text/html
#alternative_order multipart/mixed multipart/related text/plain
auto_view text/html
set mailcap_path = "~/.config/mutt/mailcap"

