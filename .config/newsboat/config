# col # item              # fg      # bg
color background          default   default        # the most bottom bar
color listnormal          default   default        # unfocused and without N
color listnormal_unread   default   default # unfocused and with N
color listfocus           default   default reverse        # focused and without N
color listfocus_unread    default   default reverse  # focused but with N
color info                default   default         # bottom and top info bars
color article             default   default        # content of an article

cleanup-on-quit yes
external-url-viewer "urlview"
browser firefox

bind-key j down
bind-key k up
bind-key j next articlelist
bind-key k prev articlelist
bind-key J next-feed articlelist
bind-key K prev-feed articlelist
bind-key g home
bind-key G end
bind-key d pagedown
bind-key u pageup
bind-key l open
bind-key h quit
bind-key U show-urls

#macro , open-in-browser
#macro v set browser "mpv"; open-in-browser; set browser librewolf
